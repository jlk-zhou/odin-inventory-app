<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Recipro</title>
</head>
<body>
  <%- include('../navbar.ejs') %>
  <h1>All Tags</h1>
  <ul>  
    <% tags.forEach(tag => { %>
      <li>
        <%= tag.name %>
        <a href="/tags/<%= tag.id %>">Show Recipes</a>
        <a href="/tags/edit/<%= tag.id %>">Edit</a> 
        <a href="/tags/delete/<%= tag.id %>">Delete</a>
      </li>
    <% }) %> 
  </ul>
</body>
</html>