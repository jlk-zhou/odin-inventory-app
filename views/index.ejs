<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Recipro</title>
</head>
<body>
  <%- include('./navbar.ejs') %> 
  <h1>All Recipes</h1> 
  <ul>
      <% recipes.forEach(recipe => { %>
        <li><%= recipe.title %>
          <a href="/recipes/<%= recipe.id %>">Show Details</a>
          <a href="/recipes/edit/<%= recipe.id %>">Edit</a>
          <a href="/recipes/delete/<%= recipe.id %>">Delete</a>
        </li>
      <% }) %>
  </ul>
</body>
</html>